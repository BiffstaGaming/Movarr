# Copy this to .env for local development.
# In Docker, pass as environment variables instead.
# Once settings are saved via the Config page (/config/settings.json),
# these env vars are only used as fallback defaults.

# Base URL of your Tautulli instance (no trailing slash)
TAUTULLI_URL=http://vm-plex.home:8181

# Tautulli API key — Settings → Web Interface → API Key
TAUTULLI_API_KEY=your_tautulli_api_key_here

# Sonarr API key — Settings → General → API Key  (optional bootstrap)
SONARR_URL=http://vm-plex.home:8989
SONARR_API_KEY=your_sonarr_api_key_here
